# ===========================================
# ETL Platform - Environment Configuration
# ===========================================

# Application
APP_NAME=ETL-Platform
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-in-production

# Database (PostgreSQL)
POSTGRES_DB=etl_platform
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_EXTERNAL_PORT=5433

# Django
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@etlplatform.local
DJANGO_SUPERUSER_PASSWORD=change-me-in-production

# OAuth2
OAUTH2_CLIENT_ID=etl-frontend-client
OAUTH2_CLIENT_SECRET=change-me-in-production

# Frontend
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_PORT=3000

# Backend
BACKEND_PORT=8000
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Mailpit (Development Email)
MAIL_HOST=mailpit
MAIL_PORT=1025
MAILPIT_UI_PORT=8025
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Redis & Celery
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# File Processing
TRFM_INBOUND_DIR=/data/trfm_inbound
TRFM_OUTBOUND_DIR=/data/trfm_outbound
